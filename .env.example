# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudinary Configuration  
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=shilposhop_artworks

# Admin Email (full access + delete)
VITE_ADMIN_EMAIL=your-admin@email.com

# Moderator Emails (comma-separated, approve/verify only — no delete)
# Example: mod1@gmail.com,mod2@gmail.com,mod3@gmail.com
VITE_MODERATOR_EMAILS=moderator1@email.com,moderator2@email.com

# Groq AI (ফ্রি) — https://console.groq.com → API Keys → Create API Key
# ⚠️ Cloudflare Dashboard → Pages → Settings → Environment Variables এও যোগ করুন
VITE_GROQ_API_KEY=আপনার_RESEND_KEY_এখানে 
